        <mxCell id="20" value="pool goroutine（單一、引擎核心）&#xa;&#xa;擁有 users map（atomic 在線數鏡像）&#xa;broadcast / join / leave / kick&#xa;週期 presence.Sync、quit 統一收尾" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
