        </mxCell>

        <mxCell id="10" value="Client（WebSocket，每連線兩個 goroutine）&#xa;readPump 讀入　|　writePump 寫出（select on quit 可優雅退出）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
